<!-- Template for inputs -->
<script type="text/html" id="customBedLevelVisulizerControls_controlTemplate_input">
	<div class="btn-group" style="display: inline-block; margin-left: 0px; margin-bottom: 5px;">
	<!-- ko foreach: input -->
		<button style="cursor: default" data-bind="text: label, enable: $root.controlViewModel.isOperational() && (!$root.controlViewModel.isPrinting() || $parent.enabled_while_printing()) && (!$root.processing() || $parent.enabled_while_graphing)" class="btn"></button>
		<input type="text" class="input-mini btn active" style="cursor: text;margin-bottom: 0px;" data-bind="attr: {placeholder: label, title: value}, value: value, enable: $root.controlViewModel.isOperational() && (!$root.controlViewModel.isPrinting() || $parent.enabled_while_printing()) && (!$root.processing() || $parent.enabled_while_graphing)">
	<!-- /ko -->
		<!-- ko template: { name: 'customBedLevelVisulizerControls_controlTemplate_command', data: $data} --><!-- /ko -->
	</div>
</script>

<!-- Template for button -->
<script type="text/html" id="customBedLevelVisulizerControls_controlTemplate_command">
	<button class="btn" data-bind="click: $root.runCustomCommand, attr: {title: (tooltip() ? tooltip : command)}, enable: $root.controlViewModel.isOperational() && (!$root.controlViewModel.isPrinting() || enabled_while_printing()) && (!$root.processing() || enabled_while_graphing)"><i data-bind="css: icon"></i> <span data-bind="text: label"/></button>
</script>

<!-- Clean Nozzle Wizard Modal (V1.2b.1) -->
<div id="bcs_clean_nozzle_modal" class="modal hide fade" tabindex="-1" role="dialog" data-backdrop="static" data-keyboard="false">
    <div class="modal-header">
        <h3><i class="fa fa-tint"></i> Clean Nozzle Wizard</h3>
    </div>
    <div class="modal-body">
        <!-- Step 0: Select material -->
        <div data-bind="visible: cleanNozzleStep() === 'select_material'">
            <p><strong>Step 1/3:</strong> Select the loaded filament material.</p>
            <p>The nozzle will be heated to the cleaning temperature for this material.</p>
            <label for="bcs_material_select">Material:</label>
            <select id="bcs_material_select" data-bind="options: cleanNozzleMaterials, value: cleanNozzleMaterial" class="input-large"></select>
            <p class="help-block">
                Temperature will be: <strong data-bind="text: cleanNozzleTargetTemp"></strong>&deg;C
            </p>
        </div>

        <!-- Step 1: Heating -->
        <div data-bind="visible: cleanNozzleStep() === 'heating'">
            <p><strong>Step 2/3:</strong> Heating nozzle to <span data-bind="text: cleanNozzleTargetTemp"></span>&deg;C for <span data-bind="text: cleanNozzleMaterial"></span>...</p>
            <p>The printer will park the head at the clean position (X0 Y0 Z50).</p>
            <p><i class="fa fa-spinner fa-spin"></i> Command sent. Wait for the nozzle to reach temperature before physically cleaning.</p>
            <div class="alert alert-info">
                <strong>Tip:</strong> Use a brass brush or tweezers. Never touch the hot nozzle with bare fingers.
            </div>
        </div>

        <!-- Step 2: Confirm clean -->
        <div data-bind="visible: cleanNozzleStep() === 'confirm'">
            <p><strong>Step 3/3:</strong> Confirm the nozzle is clean.</p>
            <div class="alert alert-success">
                Once the nozzle tip is free of plastic residue, press "Done". You can now proceed with Z-Offset calibration if needed.
            </div>
        </div>

        <!-- Step 3: Done -->
        <div data-bind="visible: cleanNozzleStep() === 'done'">
            <div class="alert alert-success">
                <i class="fa fa-check"></i> Nozzle cleaned. You may close this wizard.
            </div>
        </div>
    </div>
    <div class="modal-footer">
        <button class="btn" data-bind="click: cleanNozzleCancel, visible: cleanNozzleStep() !== 'done'">Cancel</button>
        <button class="btn btn-primary" data-bind="click: cleanNozzleStart, visible: cleanNozzleStep() === 'select_material'">Start Heating</button>
        <button class="btn btn-primary" data-bind="click: cleanNozzleProceed, visible: cleanNozzleStep() === 'heating'">Temperature Reached</button>
        <button class="btn btn-success" data-bind="click: cleanNozzleDone, visible: cleanNozzleStep() === 'confirm'">Done - Nozzle Clean</button>
        <button class="btn" data-bind="click: cleanNozzleClose, visible: cleanNozzleStep() === 'done'">Close</button>
    </div>
</div>

