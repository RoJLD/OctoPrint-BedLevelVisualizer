<!-- Clean Nozzle Wizard Modal (V1.2b.1) -->
<div id="bcs_clean_nozzle_modal" class="modal hide fade" tabindex="-1" role="dialog" data-backdrop="static" data-keyboard="false">
    <div class="modal-header">
        <h3><i class="fa fa-tint"></i> Clean Nozzle Wizard</h3>
    </div>
    <div class="modal-body">
        <!-- Step 0: Select material -->
        <div data-bind="visible: cleanNozzleStep() === 'select_material'">
            <p><strong>Step 1/3:</strong> Select the loaded filament material.</p>
            <p>The nozzle will be heated to the cleaning temperature for this material.</p>
            <label for="bcs_material_select">Material:</label>
            <select id="bcs_material_select" data-bind="options: cleanNozzleMaterials, value: cleanNozzleMaterial" class="input-large"></select>
            <p class="help-block">
                Temperature will be: <strong data-bind="text: cleanNozzleTargetTemp"></strong>&deg;C
            </p>
        </div>

        <!-- Step 1: Heating -->
        <div data-bind="visible: cleanNozzleStep() === 'heating'">
            <p><strong>Step 2/3:</strong> Heating nozzle to <span data-bind="text: cleanNozzleTargetTemp"></span>&deg;C for <span data-bind="text: cleanNozzleMaterial"></span>...</p>
            <p>The printer will park the head at the clean position (X0 Y0 Z50).</p>
            <p><i class="fa fa-spinner fa-spin"></i> Command sent. Wait for the nozzle to reach temperature before physically cleaning.</p>
            <div class="alert alert-info">
                <strong>Tip:</strong> Use a brass brush or tweezers. Never touch the hot nozzle with bare fingers.
            </div>
        </div>

        <!-- Step 2: Confirm clean -->
        <div data-bind="visible: cleanNozzleStep() === 'confirm'">
            <p><strong>Step 3/3:</strong> Confirm the nozzle is clean.</p>
            <div class="alert alert-success">
                Once the nozzle tip is free of plastic residue, press "Done". You can now proceed with Z-Offset calibration if needed.
            </div>
        </div>

        <!-- Step 3: Done -->
        <div data-bind="visible: cleanNozzleStep() === 'done'">
            <div class="alert alert-success">
                <i class="fa fa-check"></i> Nozzle cleaned. You may close this wizard.
            </div>
        </div>
    </div>
    <div class="modal-footer">
        <button class="btn" data-bind="click: cleanNozzleCancel, visible: cleanNozzleStep() !== 'done'">Cancel</button>
        <button class="btn btn-primary" data-bind="click: cleanNozzleStart, visible: cleanNozzleStep() === 'select_material'">Start Heating</button>
        <button class="btn btn-primary" data-bind="click: cleanNozzleProceed, visible: cleanNozzleStep() === 'heating'">Temperature Reached</button>
        <button class="btn btn-success" data-bind="click: cleanNozzleDone, visible: cleanNozzleStep() === 'confirm'">Done - Nozzle Clean</button>
        <button class="btn" data-bind="click: cleanNozzleClose, visible: cleanNozzleStep() === 'done'">Close</button>
    </div>
</div>

<!-- Z-Offset Paper Test Wizard Modal (V1.2b.2) -->
<div id="bcs_zoffset_modal" class="modal hide fade" tabindex="-1" role="dialog" data-backdrop="static" data-keyboard="false" style="width: 600px; margin-left: -300px;">
    <div class="modal-header">
        <h3><i class="fa fa-arrows-v"></i> Z-Offset Paper Test Wizard</h3>
    </div>
    <div class="modal-body">
        <!-- Intro -->
        <div data-bind="visible: zOffsetStep() === 'intro'">
            <p>This wizard calibrates your Z-offset using the paper test method.</p>
            <div class="alert alert-warning">
                <strong>Important:</strong> Clean the nozzle BEFORE starting. A dirty nozzle will falsify the measurement by 0.1-0.2mm.
            </div>
            <p><strong>Prepare:</strong> A sheet of standard paper (80gsm) or a business card.</p>
            <p><strong>Duration:</strong> 2-3 minutes.</p>
        </div>

        <!-- Homing -->
        <div data-bind="visible: zOffsetStep() === 'homing'">
            <p><strong>Step 1/4:</strong> Homing all axes and moving to bed center...</p>
            <p><i class="fa fa-spinner fa-spin"></i> Printer is homing. Wait for completion.</p>
            <p>Current target Z: <strong data-bind="text: zOffsetCurrentZ"></strong> mm</p>
        </div>

        <!-- Descending / Paper test -->
        <div data-bind="visible: zOffsetStep() === 'descending'">
            <p><strong>Step 2/4:</strong> Paper test — slide the paper under the nozzle.</p>
            <p>Current Z: <strong data-bind="text: zOffsetCurrentZ"></strong> mm</p>
            <div class="alert alert-info">
                Slide the paper. Select the feeling:
            </div>
            <div class="btn-group">
                <button class="btn btn-large btn-success" data-bind="click: function() { zOffsetTooLoose(); }">
                    <i class="fa fa-arrow-down"></i> Too loose (lower nozzle)
                </button>
                <button class="btn btn-large btn-primary" data-bind="click: function() { zOffsetJustRight(); }">
                    <i class="fa fa-check"></i> Just right (slight resistance)
                </button>
                <button class="btn btn-large btn-warning" data-bind="click: function() { zOffsetTooTight(); }">
                    <i class="fa fa-arrow-up"></i> Too tight (raise nozzle)
                </button>
            </div>
            <p class="help-block" style="margin-top: 15px;">Step size: <strong data-bind="text: zOffsetStepSize"></strong> mm (auto-refines)</p>
        </div>

        <!-- Confirm -->
        <div data-bind="visible: zOffsetStep() === 'confirm'">
            <p><strong>Step 3/4:</strong> Confirm and save.</p>
            <div class="alert alert-success">
                Z-offset measured: <strong data-bind="text: zOffsetMeasured"></strong> mm<br>
                This will be saved via <code>M851 Z<span data-bind="text: zOffsetMeasured"></span></code> + <code>M500</code>.
            </div>
            <p>After saving, a baseline probe measurement (G30 x3) will be stored for drift detection.</p>
        </div>

        <!-- Saving -->
        <div data-bind="visible: zOffsetStep() === 'saving'">
            <p><strong>Step 4/4:</strong> Saving to EEPROM + baseline probe...</p>
            <p><i class="fa fa-spinner fa-spin"></i> Please wait.</p>
        </div>

        <!-- Done -->
        <div data-bind="visible: zOffsetStep() === 'done'">
            <div class="alert alert-success">
                <i class="fa fa-check"></i> Z-Offset calibrated and saved.<br>
                Value: <strong data-bind="text: zOffsetMeasured"></strong> mm<br>
                Baseline stored for future drift detection.
            </div>
        </div>
    </div>
    <div class="modal-footer">
        <button class="btn" data-bind="click: zOffsetCancel, visible: zOffsetStep() !== 'done' && zOffsetStep() !== 'saving'">Cancel</button>
        <button class="btn btn-primary" data-bind="click: zOffsetStart, visible: zOffsetStep() === 'intro'">Start</button>
        <button class="btn btn-primary" data-bind="click: zOffsetProceedToDescend, visible: zOffsetStep() === 'homing'">Homing Done - Start Descend</button>
        <button class="btn btn-success" data-bind="click: zOffsetSave, visible: zOffsetStep() === 'confirm'">Save</button>
        <button class="btn" data-bind="click: zOffsetClose, visible: zOffsetStep() === 'done'">Close</button>
    </div>
</div>

<!-- Tramming Wizard Modal (V1.2b.3) -->
<div id="bcs_tramming_modal" class="modal hide fade" tabindex="-1" role="dialog" data-backdrop="static" data-keyboard="false" style="width: 750px; margin-left: -375px;">
    <div class="modal-header">
        <h3><i class="fa fa-wrench"></i> Tramming Wizard</h3>
    </div>
    <div class="modal-body">
        <!-- Intro -->
        <div data-bind="visible: trammingStep() === 'intro'">
            <p>This wizard guides manual bed leveling by capturing a mesh and computing screw adjustments.</p>
            <div class="alert alert-info">
                <strong>Prerequisites:</strong>
                <ul>
                    <li>Bed heated to your typical printing temperature (recommended)</li>
                    <li>Nozzle is clean</li>
                    <li>Probe (BLTouch, etc.) is operational</li>
                </ul>
            </div>
            <p>Current iteration: <strong>0</strong> &mdash; Target variance: &lt; <strong data-bind="text: trammingThreshold"></strong> mm</p>
        </div>

        <!-- Capturing mesh -->
        <div data-bind="visible: trammingStep() === 'capturing'">
            <p><strong>Iteration <span data-bind="text: trammingIteration"></span>:</strong> Capturing bed mesh via G29...</p>
            <p><i class="fa fa-spinner fa-spin"></i> This takes 1-3 minutes depending on probe count.</p>
            <div class="alert alert-info">Do NOT touch the printer during probing.</div>
        </div>

        <!-- Adjustments -->
        <div data-bind="visible: trammingStep() === 'adjustments'">
            <p><strong>Iteration <span data-bind="text: trammingIteration"></span> &mdash; Mesh captured.</strong></p>
            <p>Variance: <strong data-bind="text: trammingVariance"></strong> mm
               <span data-bind="visible: trammingWithinThreshold, text: ' &#10003; within threshold'" style="color: #5cb85c;"></span>
               <span data-bind="visible: !trammingWithinThreshold(), text: ' &#10007; above threshold'" style="color: #d9534f;"></span>
            </p>

            <div class="alert alert-info" data-bind="visible: trammingWithinThreshold">
                <strong>Bed is within tolerance.</strong> You can finalize now, or iterate once more for precision.
            </div>

            <h4>Screw Adjustments (relative to center):</h4>
            <table class="table table-condensed">
                <thead>
                    <tr><th>Screw</th><th>Offset (mm)</th><th>Turns</th><th>Direction</th><th>Instruction</th></tr>
                </thead>
                <tbody data-bind="foreach: trammingAdjustmentRows">
                    <tr>
                        <td><strong data-bind="text: name"></strong></td>
                        <td data-bind="text: offset_mm"></td>
                        <td data-bind="text: turns"></td>
                        <td>
                            <span class="label" data-bind="text: direction, css: { 'label-success': direction === 'CW', 'label-warning': direction === 'CCW' }"></span>
                        </td>
                        <td data-bind="text: instruction"></td>
                    </tr>
                </tbody>
            </table>

            <div class="alert alert-warning">
                <strong>Screw positions:</strong> FL = front-left, FR = front-right, BL = back-left, BR = back-right.
                Turn the physical screws <strong>under the bed</strong> (clockwise = raise bed / tighten, counter-clockwise = lower bed / loosen).
            </div>

            <p>After adjusting the screws, click "Re-measure" to verify, or "Done" if satisfied.</p>
        </div>

        <!-- Saving -->
        <div data-bind="visible: trammingStep() === 'saving'">
            <p><strong>Saving tramming state...</strong></p>
            <p><i class="fa fa-spinner fa-spin"></i></p>
        </div>

        <!-- Done -->
        <div data-bind="visible: trammingStep() === 'done'">
            <div class="alert alert-success">
                <i class="fa fa-check"></i> Tramming complete after <strong data-bind="text: trammingIteration"></strong> iteration(s).<br>
                Final variance: <strong data-bind="text: trammingVariance"></strong> mm
            </div>
        </div>
    </div>
    <div class="modal-footer">
        <button class="btn" data-bind="click: trammingCancel, visible: trammingStep() !== 'done' && trammingStep() !== 'saving'">Cancel</button>
        <button class="btn btn-primary" data-bind="click: trammingStart, visible: trammingStep() === 'intro'">Start Mesh Capture</button>
        <button class="btn btn-info" data-bind="click: trammingStart, visible: trammingStep() === 'adjustments'">Re-measure</button>
        <button class="btn btn-success" data-bind="click: trammingFinalize, visible: trammingStep() === 'adjustments'">Done - Save</button>
        <button class="btn" data-bind="click: trammingClose, visible: trammingStep() === 'done'">Close</button>
    </div>
</div>

<!-- Full Calibration Orchestrator Modal (V1.2b.4) -->
<div id="bcs_fullcal_modal" class="modal hide fade" tabindex="-1" role="dialog" data-backdrop="static" data-keyboard="false" style="width: 700px; margin-left: -350px;">
    <div class="modal-header">
        <h3><i class="fa fa-magic"></i> Full Calibration Orchestrator</h3>
    </div>
    <div class="modal-body">
        <!-- Intro -->
        <div data-bind="visible: fullCalStep() === 'intro'">
            <p>Based on your current bed health score (<strong data-bind="text: bedHealthScore"></strong>/100), the system recommends:</p>
            <div class="alert" data-bind="css: fullCalRecommendationClass">
                <strong data-bind="text: fullCalRecommendationLabel"></strong>
            </div>
            <h4>Calibration plan:</h4>
            <ol data-bind="foreach: fullCalQueue">
                <li>
                    <span data-bind="text: $data.label"></span>
                    <span class="muted" data-bind="text: ' — ' + $data.description"></span>
                </li>
            </ol>
            <div class="alert alert-info" data-bind="visible: fullCalQueue().length === 0">
                Bed is in optimal condition. No calibration needed right now.
            </div>
            <p class="help-block">You can skip individual steps from within their respective wizards.</p>
        </div>

        <!-- Running between steps -->
        <div data-bind="visible: fullCalStep() === 'running'">
            <h4>Progress:</h4>
            <div class="progress">
                <div class="bar" data-bind="style: { width: fullCalProgressPct() + '%' }"></div>
            </div>
            <p>Step <strong data-bind="text: fullCalCurrentIndex() + 1"></strong> / <strong data-bind="text: fullCalQueue().length"></strong>
               — <strong data-bind="text: fullCalCurrentLabel"></strong></p>
            <ul data-bind="foreach: fullCalQueue">
                <li>
                    <span data-bind="visible: $index() < $parent.fullCalCurrentIndex(), text: '✓ ' + $data.label" style="color: #5cb85c;"></span>
                    <span data-bind="visible: $index() === $parent.fullCalCurrentIndex(), text: '▶ ' + $data.label" style="color: #428bca; font-weight: bold;"></span>
                    <span data-bind="visible: $index() > $parent.fullCalCurrentIndex(), text: '○ ' + $data.label" style="color: #999;"></span>
                </li>
            </ul>
            <p><i class="fa fa-spinner fa-spin"></i> Wizard active in another window. Complete it (or cancel) to advance.</p>
        </div>

        <!-- Done -->
        <div data-bind="visible: fullCalStep() === 'done'">
            <div class="alert alert-success">
                <i class="fa fa-check"></i> Full calibration complete!
            </div>
            <p>New bed health score: <strong data-bind="text: bedHealthScore"></strong>/100</p>
            <ul data-bind="foreach: fullCalQueue">
                <li><span data-bind="text: '✓ ' + $data.label"></span></li>
            </ul>
        </div>
    </div>
    <div class="modal-footer">
        <button class="btn" data-bind="click: fullCalCancel, visible: fullCalStep() !== 'done'">Cancel</button>
        <button class="btn btn-primary" data-bind="click: fullCalRun, visible: fullCalStep() === 'intro' && fullCalQueue().length > 0">Run Calibration</button>
        <button class="btn" data-bind="click: fullCalClose, visible: fullCalStep() === 'done' || (fullCalStep() === 'intro' && fullCalQueue().length === 0)">Close</button>
    </div>
</div>

